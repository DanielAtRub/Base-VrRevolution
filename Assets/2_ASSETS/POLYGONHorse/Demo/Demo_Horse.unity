  m_Name: 
  m_EditorClassIdentifier: 
  ShowEvents: 1
  ID:
    UseConstant: 1
    ConstantValue: 0
    Variable: {fileID: 0}
  Auto: 1
  InvokeOnEnable: 1
  Description: 'Check Stamina Stat Value.  Connected with Stat[Stamina].OnValueChanged

    -
    Disable Dodge if is less than 25.

    - Enable Dodge if is greater than 25. '
  ShowDescription: 1
  debug: 0
  value:
    UseConstant: 1
    ConstantValue: 0
    Variable: {fileID: 0}
  Raise:
    m_PersistentCalls:
      m_Calls: []
  compare:
  - active: 1
    name: 'Stamina Lower Than '
    description: 'Disable the Dodge Mode if the Stamina is lower than 25.

      Disable
      the 1st  comparer and Enable the second one.'
    comparer: 2
    Value:
      UseConstant: 1
      ConstantValue: 25
      Variable: {fileID: 0}
    Response:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 0}
          m_TargetAssemblyTypeName: 
          m_MethodName: Mode_Disable
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 11400000, guid: 7888596ce3530b145bc15622fac8a6c4, type: 2}
            m_ObjectArgumentAssemblyTypeName: MalbersAnimations.ModeID, Assembly-CSharp
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 1381187946113028553}
          m_TargetAssemblyTypeName: 
          m_MethodName: Index_Disable
          m_Mode: 3
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 1381187946113028553}
          m_TargetAssemblyTypeName: 
          m_MethodName: Index_Enable
          m_Mode: 3
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 1
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - active: 1
    name: 'Stamina Greater Than '
    description: 'Enable the Dodge Mode if the Stamina is greater than 25.

      Disable
      the 2nd comparer and Enable the First one.'
    comparer: 1
    Value:
      UseConstant: 1
      ConstantValue: 25
      Variable: {fileID: 0}
    Response:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 0}
          m_TargetAssemblyTypeName: 
          m_MethodName: Mode_Enable
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 11400000, guid: 7888596ce3530b145bc15622fac8a6c4, type: 2}
